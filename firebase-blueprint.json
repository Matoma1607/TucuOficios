{
  "entities": {
    "Job": {
      "title": "Job",
      "description": "A job post by a professional",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the service" },
        "category": { "type": "string", "description": "Category of the service" },
        "zone": { "type": "string", "description": "Location of the service" },
        "professionalName": { "type": "string", "description": "Name of the professional" },
        "professionalId": { "type": "string", "description": "UID of the professional" },
        "whatsapp": { "type": "string", "description": "WhatsApp number" },
        "imageUrl": { "type": "string", "description": "URL of the job photo" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["title", "category", "zone", "professionalName", "professionalId", "whatsapp", "imageUrl", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A professional user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "displayName", "email", "role"]
    }
  },
  "firestore": {
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Collection of job posts"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
